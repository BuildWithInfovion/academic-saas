generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Institution {
  id              String    @id @default(cuid())
  name            String
  code            String    @unique
  planCode        String
  institutionType String
  status          String    @default("active")
  features        Json?
  address         String?
  phone           String?
  email           String?
  website         String?
  board           String?
  logoUrl         String?
  principalName   String?
  tagline         String?
  affiliationNo   String?

  // Legal & Compliance (India-specific)
  udiseCode           String?  // UDISE+ government identifier
  gstin               String?  // GST registration number
  pan                 String?  // PAN for financial documents
  recognitionNo       String?  // State/board recognition number
  foundedYear         Int?     // Year of establishment
  mediumOfInstruction String?  // English / Hindi / Both / Regional
  schoolType          String?  // Co-ed / Boys / Girls
  managementType      String?  // Private / Government / Aided / Unaided

  // Document Branding
  stampUrl            String?  // School seal / official stamp image
  signatureUrl        String?  // Principal signature image

  // Bank Details (printed on fee receipts)
  bankName            String?
  bankAccountNo       String?
  bankIfsc            String?
  bankBranch          String?
  bankAccountHolder   String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  students           Student[]
  users              User[]
  roles              Role[]
  auditLogs          AuditLog[]
  academicUnits      AcademicUnit[]
  academicYears      AcademicYear[]
  inquiries          Inquiry[]
  subjects           Subject[]
  attendanceSessions AttendanceSession[]
  attendanceRecords  AttendanceRecord[]
  feeHeads           FeeHead[]
  feeStructures      FeeStructure[]
  feePayments        FeePayment[]
  exams              Exam[]
  examResults        ExamResult[]
  announcements          Announcement[]
  timetableSlots         TimetableSlot[]
  timetableCovers        TimetableCover[]
  periodConfigs          PeriodConfig[]
  passwordResetRequests  PasswordResetRequest[]
  subscription           Subscription?
  staffAttendance        StaffAttendance[]
  staffLeaveRequests     StaffLeaveRequest[]
  transferCertificates   TransferCertificate[]
  supportTickets         SupportTicket[]
  calendarEvents         CalendarEvent[]
  passwordResetOtps      PasswordResetOtp[]
  salaryStructures       SalaryStructure[]
  staffSalaryProfiles    StaffSalaryProfile[]
  salaryRecords          SalaryRecord[]
  studentDocuments       StudentDocument[]
  staffProfiles          StaffProfile[]
  // Fee Plan System V2
  feeCategories          FeeCategory[]     @relation("InstitutionFeeCategories")
  feePlans               FeePlan[]         @relation("InstitutionFeePlans")
  feeCollections         FeeCollection[]   @relation("InstitutionFeeCollections")
  feeConcessions         FeeConcession[]   @relation("InstitutionFeeConcessions")

  // Messaging
  conversations          Conversation[]

  @@map("institutions")
}

model Student {
  id                    String      @id @default(cuid())
  institutionId         String
  admissionNo           String
  rollNo                String?

  firstName             String
  middleName            String?
  lastName              String
  dateOfBirth           DateTime?
  placeOfBirth          String?
  gender                String?
  phone                 String?
  email                 String?
  motherTongue          String?

  // FATHER
  fatherName            String?
  fatherOccupation      String?
  fatherQualification   String?
  fatherEmail           String?
  fatherAadhar          String?

  // MOTHER
  motherName            String?
  motherOccupation      String?
  motherQualification   String?
  motherEmail           String?
  motherAadhar          String?

  // CONTACTS
  parentPhone           String?
  secondaryPhone        String?

  // FINANCIAL
  annualIncome          String?
  isEwsCategory         Boolean   @default(false)

  // EMERGENCY CONTACT
  emergencyContactName      String?
  emergencyContactRelation  String?
  emergencyContactPhone     String?

  // ADDRESS
  address               String?   // house no / flat no / street line
  locality              String?   // colony / locality / village
  city                  String?
  state                 String?
  pinCode               String?

  // DEMOGRAPHIC FIELDS
  bloodGroup            String?
  nationality           String?   @default("Indian")
  religion              String?
  casteCategory         String?   // General | OBC | SC | ST
  aadharNumber          String?

  // DISABILITY & HEALTH
  hasDisability         Boolean   @default(false)
  disabilityDetails     String?
  medicalConditions     String?   // allergies, chronic conditions

  // SIBLING LINKING
  siblingGroupId        String?

  // ADMISSION
  admissionDate         DateTime?
  academicUnitId        String?

  status                String      @default("active")

  // PREVIOUS SCHOOL / TC
  tcFromPrevious        String?     @default("not_applicable")
  tcReceivedDate        DateTime?
  tcPreviousInstitution String?
  previousClass         String?
  previousBoard         String?
  previousMarks         String?

  // USER ACCOUNT LINKING
  userId                String?     @unique  // student portal login
  parentUserId          String?              // parent portal login (first parent)

  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  deletedAt             DateTime?

  institution           Institution  @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  academicUnit          AcademicUnit? @relation(fields: [academicUnitId], references: [id])
  userAccount           User?        @relation("StudentUser", fields: [userId], references: [id])
  parentUser            User?        @relation("StudentParent", fields: [parentUserId], references: [id])

  attendanceRecords     AttendanceRecord[]
  feePayments           FeePayment[]
  examResults           ExamResult[]
  transferCertificates  TransferCertificate[]
  documents             StudentDocument[]
  feeCollections        FeeCollection[]   @relation("StudentFeeCollections")
  feeConcessions        FeeConcession[]   @relation("StudentFeeConcessions")
  conversations         Conversation[]

  @@unique([institutionId, admissionNo])
  @@index([institutionId])
  @@index([academicUnitId])
  @@index([userId])
  @@index([parentUserId])
  @@index([institutionId, status])            // active student list queries
  @@index([institutionId, parentUserId])      // parent notification: find children
  @@map("students")
}

model AcademicYear {
  id            String   @id @default(cuid())
  institutionId String
  name          String   // e.g. "2025-26"
  startDate     DateTime
  endDate       DateTime
  isCurrent     Boolean  @default(false)
  createdAt     DateTime @default(now())

  institution   Institution    @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  academicUnits AcademicUnit[]
  feeStructures FeeStructure[]
  exams         Exam[]
  feePlans      FeePlan[]      @relation("AcademicYearFeePlans")

  @@unique([institutionId, name])
  @@index([institutionId])
  @@map("academic_years")
}

model AcademicUnit {
  id              String   @id @default(cuid())
  institutionId   String
  academicYearId  String?

  name            String
  displayName     String?

  level           Int
  parentId        String?

  classTeacherUserId String?

  createdAt       DateTime @default(now())
  deletedAt       DateTime?

  institution     Institution   @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  academicYear    AcademicYear? @relation(fields: [academicYearId], references: [id])
  classTeacher    User?         @relation("ClassTeacherUnit", fields: [classTeacherUserId], references: [id])

  parent          AcademicUnit?  @relation("AcademicHierarchy", fields: [parentId], references: [id])
  children        AcademicUnit[] @relation("AcademicHierarchy")

  students            Student[]
  unitSubjects        AcademicUnitSubject[]
  attendanceSessions  AttendanceSession[]
  feeStructures       FeeStructure[]
  examSubjects        ExamSubject[]
  timetableSlots      TimetableSlot[]
  timetableCovers     TimetableCover[]
  feePlanClassMaps    FeePlanClassMap[]

  @@index([institutionId])
  @@index([parentId])
  @@index([academicYearId])
  @@index([classTeacherUserId])
  @@map("academic_units")
}

model Inquiry {
  id            String   @id @default(cuid())
  institutionId String

  firstName     String
  lastName      String
  phone         String
  email         String?
  address       String?

  classInterest String?
  academicYearId String?

  status        String   @default("new") // new | contacted | visited | enrolled | dropped

  notes         String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  institution   Institution  @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId])
  @@index([status])
  @@map("inquiries")
}

model User {
  id               String    @id @default(cuid())
  institutionId    String
  name             String?
  email            String?
  phone            String?
  passwordHash     String?
  isActive         Boolean   @default(true)
  lastLoginAt      DateTime?
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())

  // TOTP (Authenticator App) — optional second factor
  totpSecret       String?               // base32 secret; null when TOTP not set up
  totpEnabled      Boolean  @default(false)
  totpBackupCodes  String[]              // SHA-256 hashes of one-time backup codes

  institution    Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  roles          UserRole[]
  auditLogs      AuditLog[]
  refreshTokens  RefreshToken[]
  studentAccount Student?    @relation("StudentUser")
  parentOf       Student[]   @relation("StudentParent")
  announcements  Announcement[]
  classTeacherOf AcademicUnit[] @relation("ClassTeacherUnit")
  subjectTeaching       AcademicUnitSubject[]  @relation("SubjectTeacher")
  passwordResetRequests PasswordResetRequest[]
  staffAttendance       StaffAttendance[]      @relation("StaffAttendanceUser")
  staffLeaveRequests    StaffLeaveRequest[]    @relation("StaffLeaveUser")
  staffLeaveApprovals   StaffLeaveRequest[]    @relation("StaffLeaveApprover")
  calendarEvents        CalendarEvent[]
  salaryProfile         StaffSalaryProfile?
  salaryRecords         SalaryRecord[]

  staffProfile          StaffProfile?
  feeCollections        FeeCollection[]   @relation("FeeCollectionCollector")
  approvedConcessions   FeeConcession[]   @relation("FeeConcessionsApprover")

  // Messaging
  parentConversations   Conversation[] @relation("ParentConversations")
  teacherConversations  Conversation[] @relation("TeacherConversations")
  sentMessages          Message[]      @relation("SentMessages")

  @@index([institutionId])
  @@index([email])                      // login lookups — auth.service queries by email
  @@index([institutionId, phone])       // phone-based login lookup
  @@map("users")
}

model StaffProfile {
  id              String   @id @default(cuid())
  institutionId   String
  userId          String   @unique

  employeeId      String?
  designation     String?
  department      String?
  dateOfJoining   DateTime?
  dateOfBirth     DateTime?
  gender          String?
  qualification   String?
  experience      String?  // e.g. "5 years"
  address         String?
  bloodGroup      String?
  aadharNumber    String?
  panNumber       String?
  bankAccount     String?
  ifscCode        String?
  bankName        String?
  emergencyContactName  String?
  emergencyContactPhone String?
  photoUrl        String?
  notes           String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  institution     Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([institutionId])
  @@map("staff_profiles")
}

model Role {
  id             String    @id @default(cuid())
  institutionId  String
  code           String
  label          String
  permissions    Json      @default("[]")

  institution    Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  users          UserRole[]

  @@index([institutionId])
  @@unique([institutionId, code])
  @@map("roles")
}

model UserRole {
  userId         String
  roleId         String
  institutionId  String

  user           User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([institutionId])
  @@map("user_roles")
}

model AuditLog {
  id             String    @id @default(cuid())
  institutionId  String
  userId         String?
  action         String
  entityType     String?
  entityId       String?
  oldValue       Json?
  newValue       Json?
  ipAddress      String?
  createdAt      DateTime  @default(now())

  institution    Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  user           User?       @relation(fields: [userId], references: [id])

  @@index([institutionId])
  @@index([userId])         // per-user audit trail queries
  @@map("audit_logs")
}

model RefreshToken {
  id             String   @id @default(cuid())
  userId         String
  institutionId  String
  tokenHash      String
  isRevoked      Boolean  @default(false)
  expiresAt      DateTime
  createdAt      DateTime @default(now())

  user           User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([institutionId])
  @@index([tokenHash])      // refresh token validation lookup
  @@map("refresh_tokens")
}

// ── ANNOUNCEMENTS ─────────────────────────────────────────────────────────────

model Announcement {
  id            String    @id @default(cuid())
  institutionId String
  title         String
  body          String
  authorUserId  String
  targetRoles   Json      @default("[\"all\"]") // ["all"] | ["teacher","student","parent"] etc.
  isPinned      Boolean   @default(false)
  expiresAt     DateTime?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  author        User        @relation(fields: [authorUserId], references: [id])

  @@index([institutionId])
  @@index([authorUserId])
  @@map("announcements")
}

// ── SUBJECT MANAGEMENT ───────────────────────────────────────────────────────

model Subject {
  id            String   @id @default(cuid())
  institutionId String
  name          String
  code          String?

  deletedAt     DateTime?
  createdAt     DateTime @default(now())

  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  unitSubjects  AcademicUnitSubject[]
  attendanceSessions AttendanceSession[]
  examSubjects  ExamSubject[]
  examResults   ExamResult[]
  timetableSlots TimetableSlot[]

  @@unique([institutionId, name])
  @@index([institutionId])
  @@map("subjects")
}

model AcademicUnitSubject {
  id              String   @id @default(cuid())
  institutionId   String
  academicUnitId  String
  subjectId       String
  teacherUserId   String?
  isClassTeacher  Boolean  @default(false)
  createdAt       DateTime @default(now())

  academicUnit    AcademicUnit @relation(fields: [academicUnitId], references: [id], onDelete: Cascade)
  subject         Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher         User?        @relation("SubjectTeacher", fields: [teacherUserId], references: [id], onDelete: SetNull)

  @@unique([academicUnitId, subjectId])
  @@index([institutionId])
  @@index([academicUnitId])
  @@index([teacherUserId])
  @@map("academic_unit_subjects")
}

// ── ATTENDANCE ───────────────────────────────────────────────────────────────

model AttendanceSession {
  id              String   @id @default(cuid())
  institutionId   String
  academicUnitId  String
  subjectId       String?
  date            DateTime @db.Date
  takenByUserId   String?
  createdAt       DateTime @default(now())

  institution     Institution  @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  academicUnit    AcademicUnit @relation(fields: [academicUnitId], references: [id], onDelete: Cascade)
  subject         Subject?     @relation(fields: [subjectId], references: [id])
  records         AttendanceRecord[]

  @@unique([academicUnitId, date, subjectId])
  @@index([institutionId])
  @@index([academicUnitId])
  @@index([date])
  @@map("attendance_sessions")
}

model AttendanceRecord {
  id              String   @id @default(cuid())
  institutionId   String
  sessionId       String
  studentId       String
  status          String   // present | absent | late | leave
  remarks         String?

  institution     Institution       @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  session         AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student         Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId])
  @@index([institutionId])
  @@index([sessionId])
  @@index([studentId])
  @@map("attendance_records")
}

// ── FEE MANAGEMENT ───────────────────────────────────────────────────────────

model FeeHead {
  id            String   @id @default(cuid())
  institutionId String
  name          String
  isCustom      Boolean  @default(false)
  deletedAt     DateTime?
  createdAt     DateTime @default(now())

  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  structures    FeeStructure[]
  payments      FeePayment[]

  @@unique([institutionId, name])
  @@index([institutionId])
  @@map("fee_heads")
}

model FeeStructure {
  id              String   @id @default(cuid())
  institutionId   String
  academicUnitId  String
  academicYearId  String
  feeHeadId       String
  amount          Float
  installmentName String?
  dueDate         DateTime? @db.Date
  deletedAt       DateTime?
  createdAt       DateTime @default(now())

  institution     Institution  @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  academicUnit    AcademicUnit @relation(fields: [academicUnitId], references: [id], onDelete: Cascade)
  academicYear    AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  feeHead         FeeHead      @relation(fields: [feeHeadId], references: [id], onDelete: Cascade)
  payments        FeePayment[]

  @@unique([academicUnitId, academicYearId, feeHeadId, installmentName])
  @@index([institutionId])
  @@index([academicUnitId])
  @@map("fee_structures")
}

model FeePayment {
  id              String   @id @default(cuid())
  institutionId   String
  studentId       String
  feeHeadId       String
  feeStructureId  String?
  academicYearId  String?
  installmentName String?
  amount          Float
  paymentMode     String   @default("cash")
  receiptNo       String
  paidOn          DateTime @db.Date
  remarks         String?
  createdAt       DateTime @default(now())

  institution    Institution  @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  student        Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  feeHead        FeeHead      @relation(fields: [feeHeadId], references: [id], onDelete: Cascade)
  feeStructure   FeeStructure? @relation(fields: [feeStructureId], references: [id])

  @@unique([institutionId, receiptNo])
  @@index([institutionId])
  @@index([studentId])
  @@index([paidOn])
  @@index([academicYearId])
  @@index([institutionId, academicYearId])
  @@index([studentId, academicYearId])
  @@index([feeStructureId])
  @@map("fee_payments")
}

// ── TIMETABLE ─────────────────────────────────────────────────────────────────

model TimetableSlot {
  id              String   @id @default(cuid())
  institutionId   String
  academicUnitId  String
  dayOfWeek       Int      // 1=Mon … 6=Sat
  periodNo        Int      // 1-based
  subjectId       String?
  teacherUserId   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  institution     Institution  @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  academicUnit    AcademicUnit @relation(fields: [academicUnitId], references: [id], onDelete: Cascade)
  subject         Subject?     @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  @@unique([academicUnitId, dayOfWeek, periodNo])
  @@index([institutionId])
  @@index([academicUnitId])
  @@map("timetable_slots")
}

model TimetableCover {
  id              String   @id @default(cuid())
  institutionId   String
  date            DateTime @db.Date
  dayOfWeek       Int      // 1=Mon … 6=Sat
  periodNo        Int
  academicUnitId  String
  subjectId       String?
  absentTeacherId String   // userId of absent teacher (no FK — mirrors TimetableSlot pattern)
  substituteId    String?  // userId of substitute assigned
  status          String   @default("uncovered")  // uncovered | covered | cancelled
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  institution  Institution  @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  academicUnit AcademicUnit @relation(fields: [academicUnitId], references: [id], onDelete: Cascade)

  @@unique([institutionId, date, academicUnitId, periodNo])
  @@index([institutionId, date])
  @@index([institutionId, absentTeacherId])
  @@index([institutionId, substituteId])
  @@map("timetable_covers")
}

model PeriodConfig {
  id            String      @id @default(cuid())
  institutionId String
  sortOrder     Int         // 1-based position in the day schedule
  label         String      // "Period 1", "Short Break", "Lunch Break"
  isBreak       Boolean     @default(false)
  startTime     String      // "08:00" (24h HH:MM)
  endTime       String      // "08:45" (24h HH:MM)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@unique([institutionId, sortOrder])
  @@index([institutionId])
  @@map("period_configs")
}

// ── EXAMINATION ───────────────────────────────────────────────────────────────

model Exam {
  id              String    @id @default(cuid())
  institutionId   String
  academicYearId  String
  name            String
  startDate       DateTime? @db.Date
  endDate         DateTime? @db.Date
  status          String    @default("draft")
  examCenter      String?   // e.g. "Main Block — Room 101"
  reportingTime   String?   // e.g. "30 minutes before exam"
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())

  institution     Institution  @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  academicYear    AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  subjects        ExamSubject[]
  results         ExamResult[]

  @@index([institutionId])
  @@index([academicYearId])
  @@map("exams")
}

model ExamSubject {
  id              String   @id @default(cuid())
  examId          String
  academicUnitId  String
  subjectId       String
  maxMarks        Float    @default(100)
  passingMarks    Float    @default(35)
  examDate        DateTime? @db.Date
  examTime        String?   // e.g. "10:00 AM – 12:00 PM"
  createdAt       DateTime @default(now())

  exam            Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  academicUnit    AcademicUnit @relation(fields: [academicUnitId], references: [id], onDelete: Cascade)
  subject         Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([examId, academicUnitId, subjectId])
  @@index([examId])
  @@index([academicUnitId])  // getExamCompleteness filters exam subjects by unit
  @@map("exam_subjects")
}

model ExamResult {
  id              String   @id @default(cuid())
  institutionId   String
  examId          String
  studentId       String
  subjectId       String
  academicUnitId  String
  marksObtained   Float?
  isAbsent        Boolean  @default(false)
  remarks         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  institution     Institution  @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  exam            Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  student         Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject         Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([examId, studentId, subjectId])
  @@index([institutionId])
  @@index([examId])
  @@index([studentId])
  @@index([academicUnitId])             // getExamCompleteness and getClassResultSummary groupBy
  @@index([examId, academicUnitId])     // composite — most result queries filter on both
  @@map("exam_results")
}

model PasswordResetRequest {
  id            String   @id @default(cuid())
  institutionId String
  userId        String
  status        String   @default("pending") // pending | approved | rejected
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([institutionId])
  @@index([userId])
  @@map("password_reset_requests")
}

// ── PLATFORM (DEVELOPER) LAYER ────────────────────────────────────────────────

model PlatformAdmin {
  id                String    @id @default(cuid())
  email             String    @unique
  passwordHash      String
  name              String
  isActive          Boolean   @default(true)
  lastLoginAt       DateTime?
  failedLoginCount  Int       @default(0)
  lockedUntil       DateTime?
  lastFailedAt      DateTime?
  activeSessionId   String?   // set on login, cleared on logout — enforces single active session
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  loginLogs         PlatformLoginLog[]
  passwordResets    PlatformPasswordReset[]

  @@map("platform_admins")
}

model PlatformLoginLog {
  id          String   @id @default(cuid())
  adminId     String
  ipAddress   String?
  userAgent   String?
  success     Boolean
  failReason  String?
  createdAt   DateTime @default(now())

  admin       PlatformAdmin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([createdAt])
  @@map("platform_login_logs")
}

model PlatformPasswordReset {
  id          String   @id @default(cuid())
  adminId     String
  tokenHash   String   @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime @default(now())

  admin       PlatformAdmin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@map("platform_password_resets")
}

// ── Staff Attendance ──────────────────────────────────────────────────────────

model StaffAttendance {
  id            String   @id @default(cuid())
  institutionId String
  userId        String
  date          DateTime @db.Date
  status        String   // present | absent | late | half_day
  clockIn       DateTime?
  clockOut      DateTime?
  note          String?
  markedById    String?  // self-marked = userId; admin override = admin userId
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  user          User        @relation("StaffAttendanceUser", fields: [userId], references: [id])

  @@unique([institutionId, userId, date])
  @@index([institutionId])
  @@index([userId])
  @@index([date])
  @@map("staff_attendance")
}

model StaffLeaveRequest {
  id            String   @id @default(cuid())
  institutionId String
  userId        String
  startDate     DateTime @db.Date
  endDate       DateTime @db.Date
  reason        String
  status        String   @default("pending") // pending | approved | rejected
  approvedById  String?
  reviewNote    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  user          User        @relation("StaffLeaveUser", fields: [userId], references: [id])
  approvedBy    User?       @relation("StaffLeaveApprover", fields: [approvedById], references: [id])

  @@index([institutionId])
  @@index([userId])
  @@map("staff_leave_requests")
}

model Subscription {
  id                String    @id @default(cuid())
  institutionId     String    @unique
  planName          String    @default("standard")
  maxStudents       Int       @default(500)
  pricePerUser      Float     @default(50)
  billingCycleYears Int       @default(1)
  totalAmount       Float
  startDate         DateTime
  endDate           DateTime
  status            String    @default("active") // active | expired | suspended | cancelled
  amountPaid        Float?
  paidAt            DateTime?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  institution       Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ── TRANSFER CERTIFICATES ─────────────────────────────────────────────────────

model TransferCertificate {
  id              String    @id @default(cuid())
  institutionId   String
  studentId       String

  // Status flow: pending_approval → approved → issued
  //                              → rejected
  status          String    @default("pending_approval")

  // Immutable snapshot of student data captured at request time.
  // Stored here so the TC document remains accurate even if the student
  // record is later edited or deleted.
  studentName       String
  admissionNo       String
  dateOfBirth       DateTime?
  gender            String?
  fatherName        String?
  motherName        String?
  nationality       String?
  religion          String?
  casteCategory     String?
  bloodGroup        String?
  classLastStudied  String
  admissionDate     DateTime?
  academicYearName  String?

  // TC fields
  conductGrade    String    @default("Good")   // Excellent | Good | Satisfactory | Poor
  reason          String?                      // why the student is leaving
  tcNumber        String?                      // set on issue: TC-2024-0001

  // Academic snapshot (government TC fields §8-12)
  subjectsStudied   String?   // comma-separated subjects at time of request
  lastExamName      String?   // e.g. "Annual Examination (2024-25)"
  lastExamResult    String?   // "Pass" | "Fail" | "N/A"
  promotionEligible String?   // "Yes" | "No" | "N/A"

  // Fee snapshot — government TC field §12: "month up to which fees paid"
  feesPaidUpToMonth String?   // e.g. "March 2025" | "N/A"

  // Attendance snapshot (current academic year at request time)
  workingDays     Int?
  presentDays     Int?

  // Fee dues status at request time (used for workflow check; not on TC document)
  hasDues         Boolean   @default(false)
  duesRemark      String?

  // Workflow actors
  requestedByUserId   String
  approvedByUserId    String?
  rejectedByUserId    String?
  rejectionRemark     String?

  requestedAt     DateTime  @default(now())
  approvedAt      DateTime?
  rejectedAt      DateTime?
  issuedAt        DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  institution     Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  student         Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([institutionId, tcNumber])   // tcNumber is null until issued; unique across institution
  @@index([institutionId])
  @@index([studentId])
  @@index([institutionId, status])
  @@map("transfer_certificates")
}

model SupportTicket {
  id              String   @id @default(cuid())
  institutionId   String
  institutionName String
  submittedBy     String   // email or phone
  submitterRole   String
  subject         String
  message         String
  status          String   @default("open")  // open | resolved
  adminNotes      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  institution     Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId])
  @@index([status])
  @@index([createdAt])
  @@map("support_tickets")
}

model CalendarEvent {
  id              String    @id @default(cuid())
  institutionId   String
  title           String
  description     String?
  // holiday | exam | event | meeting | vacation | other
  eventType       String    @default("event")
  startDate       DateTime
  endDate         DateTime
  isAllDay        Boolean   @default(true)
  createdByUserId String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  institution     Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  createdBy       User        @relation(fields: [createdByUserId], references: [id])

  @@index([institutionId])
  @@index([institutionId, startDate])
  @@map("calendar_events")
}

// ── PASSWORD RESET OTP ────────────────────────────────────────────────────────
// Short-lived 6-digit OTP sent to staff/operator email for self-service reset.
// Single-use, 10-minute TTL. Parents cannot self-reset — operator resets directly.

model PasswordResetOtp {
  id            String   @id @default(cuid())
  institutionId String
  email         String
  otpHash       String   // SHA-256 hex of the raw 6-digit OTP
  expiresAt     DateTime
  isUsed        Boolean  @default(false)
  createdAt     DateTime @default(now())

  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId])
  @@index([email, institutionId])  // reset OTP lookup
  @@index([expiresAt])             // cleanup job index
  @@map("password_reset_otps")
}

// ── SALARY MANAGEMENT ─────────────────────────────────────────────────────────

model SalaryStructure {
  id            String   @id @default(cuid())
  institutionId String
  name          String   // e.g. "Teacher Grade A", "Non-Teaching Basic"
  description   String?

  basicSalary            Float    @default(0)
  houseRentAllowance     Float    @default(0)
  medicalAllowance       Float    @default(0)
  transportAllowance     Float    @default(0)
  otherAllowances        Json?    // [{name: string, amount: number}]

  providentFund          Float    @default(0)
  professionalTax        Float    @default(0)
  otherDeductions        Json?    // [{name: string, amount: number}]

  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  institution   Institution          @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  staffProfiles StaffSalaryProfile[]

  @@unique([institutionId, name])
  @@index([institutionId])
  @@map("salary_structures")
}

model StaffSalaryProfile {
  id              String   @id @default(cuid())
  institutionId   String
  userId          String   @unique
  structureId     String?

  basicSalary            Float    @default(0)
  houseRentAllowance     Float    @default(0)
  medicalAllowance       Float    @default(0)
  transportAllowance     Float    @default(0)
  otherAllowances        Json?    // [{name: string, amount: number}]

  providentFund          Float    @default(0)
  professionalTax        Float    @default(0)
  otherDeductions        Json?    // [{name: string, amount: number}]

  effectiveFrom   DateTime @db.Date
  notes           String?
  isActive        Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  institution     Institution       @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  structure       SalaryStructure?  @relation(fields: [structureId], references: [id], onDelete: SetNull)
  salaryRecords   SalaryRecord[]

  @@index([institutionId])
  @@index([userId])
  @@map("staff_salary_profiles")
}

model SalaryRecord {
  id              String   @id @default(cuid())
  institutionId   String
  userId          String
  profileId       String

  month           Int   // 1–12
  year            Int

  // Snapshot at generation time
  basicSalary            Float    @default(0)
  houseRentAllowance     Float    @default(0)
  medicalAllowance       Float    @default(0)
  transportAllowance     Float    @default(0)
  otherAllowances        Json?    // [{name: string, amount: number}]
  grossSalary            Float    @default(0)

  providentFund          Float    @default(0)
  professionalTax        Float    @default(0)
  otherDeductions        Json?    // [{name: string, amount: number}]
  totalDeductions        Float    @default(0)

  netSalary              Float    @default(0)

  // pending | paid | on_hold
  status          String   @default("pending")

  paidOn          DateTime?
  paymentMode     String?   // cash | bank_transfer | cheque | upi | other
  paymentReference String?
  remarks         String?
  markedPaidById  String?

  generatedAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt

  institution     Institution        @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  user            User               @relation(fields: [userId], references: [id])
  profile         StaffSalaryProfile @relation(fields: [profileId], references: [id])

  @@unique([institutionId, userId, month, year])
  @@index([institutionId])
  @@index([institutionId, month, year])
  @@index([userId])
  @@map("salary_records")
}

// ─── Student Documents ────────────────────────────────────────────────────────
// Stores scanned/uploaded documents submitted at time of admission.
// Files live in Cloudinary under: <cloudName>/<institutionId>/<studentId>/
// The publicId field is the Cloudinary public_id needed to delete the file later.
model StudentDocument {
  id            String    @id @default(cuid())
  institutionId String
  studentId     String

  // Document classification
  // aadhaar | birth_certificate | previous_tc | caste_certificate |
  // migration_certificate | previous_marksheet | medical_certificate |
  // income_certificate | disability_certificate | residential_proof |
  // passport_photo | parent_id_proof | other
  type          String

  label         String    // Human-readable name shown in UI
  url           String    // Cloudinary secure_url (https, served via CDN)
  publicId      String    // Cloudinary public_id — required for deletion
  format        String?   // pdf | jpg | png | webp etc.
  sizeBytes     Int?      // Original file size for display

  uploadedByUserId String?
  uploadedAt    DateTime  @default(now())
  deletedAt     DateTime?

  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  student       Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([institutionId])
  @@index([studentId])
  @@index([institutionId, studentId])
  @@map("student_documents")
}

// ── FEE MANAGEMENT V2 — Plan-based System ────────────────────────────────────
// Schools create a FeePlan (with items + installments), assign it to classes,
// optionally grant per-student concessions, then record FeeCollections against
// specific installments. Replaces the per-class FeeStructure setup flow.

model FeeCategory {
  id            String    @id @default(cuid())
  institutionId String
  name          String
  type          String    @default("CUSTOM") // TUITION|TRANSPORT|EXAM|LAB|LIBRARY|ACTIVITY|SPORTS|DEVELOPMENT|HOSTEL|CUSTOM
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())

  institution  Institution   @relation("InstitutionFeeCategories", fields: [institutionId], references: [id], onDelete: Cascade)
  planItems    FeePlanItem[]
  collections  FeeCollection[]

  @@unique([institutionId, name])
  @@index([institutionId])
  @@map("fee_categories")
}

model FeePlan {
  id             String    @id @default(cuid())
  institutionId  String
  academicYearId String
  name           String
  description    String?
  isActive       Boolean   @default(true)
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())

  institution  Institution   @relation("InstitutionFeePlans", fields: [institutionId], references: [id], onDelete: Cascade)
  academicYear AcademicYear  @relation("AcademicYearFeePlans", fields: [academicYearId], references: [id])
  items        FeePlanItem[]
  classMaps    FeePlanClassMap[]

  @@unique([institutionId, name, academicYearId])
  @@index([institutionId])
  @@index([academicYearId])
  @@map("fee_plans")
}

model FeePlanItem {
  id            String  @id @default(cuid())
  feePlanId     String
  feeCategoryId String
  totalAmount   Float

  feePlan      FeePlan            @relation(fields: [feePlanId], references: [id], onDelete: Cascade)
  feeCategory  FeeCategory        @relation(fields: [feeCategoryId], references: [id])
  installments FeePlanInstallment[]
  collections  FeeCollection[]
  concessions  FeeConcession[]

  @@unique([feePlanId, feeCategoryId])
  @@map("fee_plan_items")
}

model FeePlanInstallment {
  id            String    @id @default(cuid())
  feePlanItemId String
  label         String    // "Term 1", "Q1", "Annual"
  amount        Float
  dueDate       DateTime? @db.Date
  sortOrder     Int       @default(0)

  feePlanItem FeePlanItem     @relation(fields: [feePlanItemId], references: [id], onDelete: Cascade)
  collections FeeCollection[]

  @@unique([feePlanItemId, label])
  @@map("fee_plan_installments")
}

model FeePlanClassMap {
  id             String @id @default(cuid())
  feePlanId      String
  academicUnitId String

  feePlan      FeePlan      @relation(fields: [feePlanId], references: [id], onDelete: Cascade)
  academicUnit AcademicUnit @relation(fields: [academicUnitId], references: [id], onDelete: Cascade)

  @@unique([feePlanId, academicUnitId])
  @@map("fee_plan_class_maps")
}

model FeeConcession {
  id               String   @id @default(cuid())
  institutionId    String
  studentId        String
  feePlanItemId    String
  amount           Float
  reason           String
  approvedByUserId String?
  createdAt        DateTime @default(now())

  institution  Institution @relation("InstitutionFeeConcessions", fields: [institutionId], references: [id], onDelete: Cascade)
  student      Student     @relation("StudentFeeConcessions", fields: [studentId], references: [id], onDelete: Cascade)
  feePlanItem  FeePlanItem @relation(fields: [feePlanItemId], references: [id], onDelete: Cascade)
  approvedBy   User?       @relation("FeeConcessionsApprover", fields: [approvedByUserId], references: [id])

  @@index([institutionId])
  @@index([studentId])
  @@map("fee_concessions")
}

model FeeCollection {
  id                   String    @id @default(cuid())
  institutionId        String
  studentId            String
  feePlanItemId        String?
  feePlanInstallmentId String?
  feeCategoryId        String
  academicYearId       String?
  amount               Float
  paymentMode          String    @default("cash")
  receiptNo            String
  paidOn               DateTime  @db.Date
  remarks              String?
  collectedByUserId    String?
  createdAt            DateTime  @default(now())

  institution        Institution        @relation("InstitutionFeeCollections", fields: [institutionId], references: [id], onDelete: Cascade)
  student            Student            @relation("StudentFeeCollections", fields: [studentId], references: [id], onDelete: Cascade)
  feePlanItem        FeePlanItem?       @relation(fields: [feePlanItemId], references: [id])
  feePlanInstallment FeePlanInstallment? @relation(fields: [feePlanInstallmentId], references: [id])
  feeCategory        FeeCategory        @relation(fields: [feeCategoryId], references: [id])
  collectedBy        User?              @relation("FeeCollectionCollector", fields: [collectedByUserId], references: [id])

  @@unique([institutionId, receiptNo])
  @@index([institutionId])
  @@index([studentId])
  @@index([paidOn])
  @@index([academicYearId])
  @@index([feePlanInstallmentId])
  @@map("fee_collections")
}

// ── MESSAGING ─────────────────────────────────────────────────────────────────
// Parent-teacher direct messaging. One conversation per parent-teacher-student
// combination. Messages are fetched by polling (no WebSocket required).

model Conversation {
  id              String   @id @default(cuid())
  institutionId   String
  parentUserId    String
  teacherUserId   String
  studentId       String?
  subject         String?  // optional topic, e.g. "Homework query"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  institution     Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  parentUser      User        @relation("ParentConversations", fields: [parentUserId], references: [id])
  teacherUser     User        @relation("TeacherConversations", fields: [teacherUserId], references: [id])
  student         Student?    @relation(fields: [studentId], references: [id])
  messages        Message[]

  @@unique([institutionId, parentUserId, teacherUserId, studentId])
  @@index([institutionId])
  @@index([parentUserId])
  @@index([teacherUserId])
  @@map("conversations")
}

model Message {
  id              String   @id @default(cuid())
  conversationId  String
  senderId        String
  content         String
  readAt          DateTime?
  createdAt       DateTime @default(now())

  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender          User         @relation("SentMessages", fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([senderId])
  @@map("messages")
}
