# ─────────────────────────────────────────────────────────────────
# Academic SaaS — Backend environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# PostgreSQL connection string (Neon, Supabase, or local Postgres)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# JWT signing secret — generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Must be at least 64 characters.
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET

# Port the backend listens on
PORT=3000

# Comma-separated allowed origins for CORS.
# Dev: http://localhost:3001
# Production: https://app.buildwithinfovion.com
CORS_ORIGIN=http://localhost:3001

# ─── Developer / QA bypass ────────────────────────────────────────
# DEV_MASTER_OTP: a fixed 6-digit code that bypasses real OTP verification.
# ONLY active when NODE_ENV != 'production'. Leave blank or unset in prod.
# Usage: any staff login — enter this code instead of the real SMS OTP.
# Example: DEV_MASTER_OTP=000000
DEV_MASTER_OTP=

# ─── SMS Provider (OTP delivery) ─────────────────────────────────
# When not set, OTPs are logged to the backend console (dev mode).
# Supported providers: fast2sms | msg91 | twilio
# SMS_PROVIDER=fast2sms
# SMS_API_KEY=<your-api-key>
# SMS_SENDER_ID=SCHOOL   # 6-char DLT sender ID (India)
