# ─────────────────────────────────────────────────────────────────
# Academic SaaS — Backend environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ─── Database (Supabase) ─────────────────────────────────────────
# DATABASE_URL: Transaction mode (port 6543) — used by the running app via PgBouncer
# DIRECT_URL:   Session mode (port 5432)    — used by Prisma migrate/seed only
#
# Find both in Supabase → Project Settings → Database → Connection string
# Transaction mode URI (copy, change port to 6543):
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Session mode URI (copy, keep port 5432):
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres"

# JWT signing secret — generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Must be at least 64 characters.
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET

# Port the backend listens on
PORT=3000

# Comma-separated allowed origins for CORS.
# Dev: http://localhost:3001
# Production: https://app.buildwithinfovion.com
CORS_ORIGIN=http://localhost:3001

# ─── Email (Resend) — password reset OTPs only ───────────────────
# Free tier: 3,000 emails/month — more than enough for password resets.
# Get your key at https://resend.com
# When not set, reset OTPs are logged to the backend console (dev mode).
RESEND_API_KEY=

# Display name + from address for outbound emails.
# Must be a verified domain in your Resend account for production use.
# EMAIL_FROM=Infovion <noreply@yourdomain.com>

# ─── Cloudinary — Student Document Storage ───────────────────────
# Free tier: 25 GB storage, 25 GB bandwidth/month — enough for early stage.
# All school documents are stored under: <cloud>/<institutionId>/<studentId>/
# Get credentials at https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── N8N Automation Webhooks (optional) ──────────────────────────
# If you self-host N8N (Railway / Render), set this to your N8N instance URL.
# When unset, all webhook.fire() calls are silently skipped.
# N8N_WEBHOOK_URL=https://your-n8n-instance.railway.app

# ─── Data Retention Cleanup ──────────────────────────────────────
# Set to "true" to log what the cleanup job WOULD delete without deleting it.
# Useful for testing before enabling real deletion in production.
# CLEANUP_DRY_RUN=false
